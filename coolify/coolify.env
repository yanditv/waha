# Coolify Environment Configuration - WAHA
# ===========================================

# Application
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
WAHA_API_KEY=REPLACE_WITH_SECURE_API_KEY

# Server
WAHA_PORT=3000
WAHA_WEB_PORT=3001
TZ=America/Lima

# Engine: webjs, noweb, gows, venom
WAHA_ENGINE=webjs

# Session
WAHA_SESSION_TIMEOUT_MS=120000
WAHA_SESSION_CLEANUP_INTERVAL_MS=60

# Logging: debug, info, warn, error
WAHA_LOG_LEVEL=info
