# WAHA Environment Variables
# Based on official Coolify docs: https://waha.devlike.pro/blog/waha-on-coolify/

# ===== SECURITY =====
WAHA_API_KEY=a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4

# ===== BASE URL =====
WAHA_BASE_URL=http://localhost:3000
WAHA_PUBLIC_URL=http://localhost:3000

# ===== DASHBOARD & SWAGGER =====
WAHA_DASHBOARD_ENABLED=True
WHATSAPP_SWAGGER_ENABLED=True

# ===== ENGINE =====
WHATSAPP_DEFAULT_ENGINE=WEBJS

# ===== LOGGING =====
WAHA_LOG_FORMAT=JSON
WAHA_LOG_LEVEL=info
WAHA_PRINT_QR=False

# ===== MEDIA STORAGE =====
WAHA_MEDIA_STORAGE=LOCAL
WHATSAPP_FILES_LIFETIME=0
WHATSAPP_FILES_FOLDER=/app/.media
