# WAHA - WhatsApp HTTP API
# https://waha.devlike.pro/docs/how-to/config/

# ===== SECURITY =====
WAHA_API_KEY=a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=admin123456789012345678901234
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=admin123456789012345678901234

# Disable Dashboard or Swagger
WAHA_DASHBOARD_ENABLED=True
WHATSAPP_SWAGGER_ENABLED=True

# ===== COMMON =====
WHATSAPP_DEFAULT_ENGINE=WEBJS
WAHA_BASE_URL=http://localhost:3000

# ===== LOGGING =====
WAHA_LOG_FORMAT=JSON
WAHA_LOG_LEVEL=info
WAHA_PRINT_QR=False

# ===== MEDIA STORAGE =====
WAHA_MEDIA_STORAGE=LOCAL
WHATSAPP_FILES_LIFETIME=0
WHATSAPP_FILES_FOLDER=/app/.media

# ===== TIMEZONE =====
TZ=America/Lima
