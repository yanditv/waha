# ===========================================
# WAHA - WhatsApp HTTP API
# ===========================================

# Dashboard (change after first run)
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=changeme_change_this_password

# API Key (change after first run - use long random string)
WAHA_API_KEY=changeme_change_this_to_random_string

# Server
WAHA_PORT=3000
WAHA_WEB_PORT=3001

# Engine: webjs, noweb, gows, venom
WAHA_ENGINE=webjs

# Session
WAHA_SESSION_TIMEOUT_MS=120000
WAHA_SESSION_CLEANUP_INTERVAL_MS=60

# Logging: debug, info, warn, error
WAHA_LOG_LEVEL=info

# Timezone
TZ=America/Lima
